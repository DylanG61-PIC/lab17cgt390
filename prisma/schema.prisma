datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id        Int    @id @default(autoincrement())
  name      String
  title     String
  email     String
  bio       String
  image_url String

  @@map("profiles") // matches your existing table in Neon
}